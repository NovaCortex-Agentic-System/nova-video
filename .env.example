# NOVA Video — Chei API necesare
# Completează înainte de primul start sau în timpul onboarding-ului

KIE_API_KEY=        # kie.ai → Settings → API Keys → Create key (video Kling, voiceover ElevenLabs, muzică Suno)
HEYGEN_API_KEY=     # app.heygen.com → Settings → API → Generate token
HEYGEN_AVATAR_ID=   # ID-ul avatarului tău personal (setat în onboarding via vid-avatar-heygen)
HEYGEN_VOICE_ID=    # opțional: ID voce clonată ElevenLabs via kie.ai Voice Cloning

# Higgsfield funcționează prin MCP, nu prin cheie în .env.
# Configurează serverul MCP în Claude Code settings cu HIGGSFIELD_API_KEY din higgsfield.com/dashboard.
